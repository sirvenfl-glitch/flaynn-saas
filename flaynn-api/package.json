{
  "name": "flaynn-api",
  "version": "1.0.0",
  "description": "Flaynn SaaS API - Secure Core",
  "main": "src/server.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch-path=./src src/server.js",
    "test": "NODE_ENV=test node --test tests/**/*.test.js",
    "test:load": "NODE_ENV=test LOAD_TEST=true node scripts/load-test.js",
    "test:smoke-delta-9": "node scripts/smoke-delta-9.mjs",
    "test:smoke-delta-13": "node scripts/smoke-delta-13.mjs",
    "build:icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/static": "^8.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.11.5",
    "pino": "^9.0.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "stripe": "^22.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "pino-pretty": "^11.0.0",
    "sharp": "^0.33.5"
  }
}
