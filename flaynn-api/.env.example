# --- CONFIGURATION DU SERVEUR ---
NODE_ENV=development
PORT=3000
# CORS : CSV des origines autorisées en prod. Default si absent :
# https://flaynn.io,https://flaynn.tech,https://flaynn.com,https://flaynn.fr
CORS_ORIGIN=http://localhost:3000,https://flaynn.io,https://flaynn.fr

# --- INTEGRATION WEBHOOK n8n ---
# URL cible du webhook n8n pour la soumission du formulaire de scoring
N8N_WEBHOOK_URL=https://n8n.flaynn.fr/webhook/scoring-submit

# --- SECURITE ---
# Token secret partagé entre Fastify et n8n pour valider la provenance des requêtes
# (Minimum 16 caractères). À générer en prod avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
N8N_SECRET_TOKEN=

# --- API CLAUDE (ANTHROPIC) ---
ANTHROPIC_API_KEY=

# --- CRM (GOOGLE SHEETS) ---
# URL du Webhook Google Apps Script pour ajouter les leads
GOOGLE_SHEETS_WEBHOOK_URL=

# --- REDIS ---
# URL de connexion Redis pour le Rate Limiting distribué
REDIS_URL=redis://127.0.0.1:6379

# --- AUTHENTIFICATION ---
# Clé secrète pour signer et vérifier les JWT
# (Minimum 32 caractères). À générer en prod avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# --- BASE DE DONNÉES ---
DATABASE_URL=postgresql://user:password@localhost:5432/flaynn_db

# --- STRIPE ---
# Clés API Stripe (live ou test selon environnement)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID Stripe pour l'abonnement BA 350€/mois (commence par price_)
STRIPE_PRICE_BA_SUBSCRIPTION=

# --- DELTA 12 — ONBOARDING BUSINESS ANGELS ---
# Secret HMAC pour signer les liens "Demander une intro" envoyés dans les digests BA.
# (Minimum 32 caractères). À générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTRO_TOKEN_SECRET=

# Whitelist d'emails admin pour /api/admin/ba/* (CSV, lowercased côté code).
# Si vide, les routes admin sont entièrement désactivées au boot.
ADMIN_EMAILS=

# Origin frontend public pour les redirects Stripe success/cancel post-checkout BA.
# Default si absent : https://flaynn.com
BA_PUBLIC_BASE_URL=http://localhost:5173

# --- URL APPLICATION ---
APP_URL=http://localhost:3000